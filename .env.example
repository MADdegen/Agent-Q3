# ═══════════════════════════════════════════════════════════════════
# Agent-Q3 — Environment Variables
# Local GGUF stack (5 models) + kimi-k2:1t-cloud monitor
# Account: nicholasjmcleod@gmail.com / Device: LN-8RDGA90Ultra
# ═══════════════════════════════════════════════════════════════════

# ── Local model assignments (Ollama pulls from HuggingFace on boot) ──
# [1] Reasoner — Kimi-VL-A3B Q4_K_M  (/v1/instruct, /v1/chat)
REASONER_MODEL=hf.co/mradermacher/Kimi-VL-A3B-Instruct-i1-GGUF:Q4_K_M

# [2] Tandem — Hermes3 8B  (/v1/tandem stage-2, /v1/coder/review stage-2)
TANDEM_MODEL=hermes3:8b

# [3] Coder — Qwen3-48B-A4B-Savant Q8_0  (/v1/code, /v1/tandem stage-3)
CODER_MODEL=hf.co/DavidAU/Qwen3-48B-A4B-Savant-Commander-Distill-12X-Closed-Open-Heretic-Uncensored-GGUF:Q8_0

# [4] Fallback — Qwopus3.6-27B Q8_0  (/v1/fallback)
FALLBACK_MODEL=hf.co/Jackrong/Qwopus3.6-27B-v1-preview-GGUF:Q8_0

# [5] Dedicated coder — Qwen3-Coder-30B-A3B Q6_K  (/v1/coder, /v1/coder/review)
CODER_DEDICATED_MODEL=hf.co/Qwen/Qwen3-Coder-30B-A3B-Instruct-GGUF:Q6_K

# ── Kimi K2 always-on monitor (Ollama Cloud — outside local router) ──
# Primary: kimi-k2:1t-cloud via ollama (requires device key mount)
# Fallback: moonshotai/kimi-k2 via OpenRouter
KIMI_K2_MODEL=kimi-k2:1t-cloud
KIMI_K2_POLL_INTERVAL_SECS=30

# ── Ollama Cloud (monitor only — mount ~/.ollama for device key) ─────
OLLAMA_CLOUD_ENABLED=true
OLLAMA_CLOUD_ACCOUNT=nicholasjmcleod@gmail.com
OLLAMA_CLOUD_DEVICE=LN-8RDGA90Ultra

# ── Compute strategy ──────────────────────────────────────────────────
# cloud_priority = Local Ollama → OpenRouter → HuggingFace → RunPod
COMPUTE_STRATEGY=cloud_priority
REQUEST_TIMEOUT_SECS=300

# ── OpenRouter (secondary compute + monitor fallback) ─────────────────
OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── HuggingFace (tertiary compute — frontier models) ─────────────────
HF_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
HF_TOKEN_2=hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
HF_TOKEN_3=hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── RunPod Serverless (quaternary — GPU burst) ────────────────────────
RUNPOD_API_KEY=rpa_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
RUNPOD_REASONER_ENDPOINT_ID=kukl55t0053lob
RUNPOD_CODER_ENDPOINT_ID=kukl55t0053lob

# ── Research / Search APIs ────────────────────────────────────────────
PERPLEXITY_API_KEY=pplx-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
EXA_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TAVILY_API_KEY=tvly-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
SMITHERY_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Shared infrastructure ─────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:PASSWORD@postgres.internal:5432/railway
REDIS_URL=redis://default:PASSWORD@redis.internal:6379

# ── Open WebUI ────────────────────────────────────────────────────────
WEBUI_SECRET_KEY=change-me-to-a-random-secret

# ── Server ────────────────────────────────────────────────────────────
PORT=8000
LOG_LEVEL=info
