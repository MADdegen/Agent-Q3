# ── Models ────────────────────────────────────────────────────────────────────
REASONER_MODEL=gemma4:e4b-instruct-q4_K_M
CODER_MODEL=qwen3.5:4b-instruct-q4_K_M

# ── Compute strategy ──────────────────────────────────────────────────────────
# Options: round_robin | load_based | local_first | hf_first | runpod_first
COMPUTE_STRATEGY=round_robin
LOCAL_WEIGHT=60
HF_WEIGHT=25
RUNPOD_WEIGHT=15

# ── HuggingFace ───────────────────────────────────────────────────────────────
HF_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
HF_REASONER_MODEL=google/gemma-4-e4b-it
HF_CODER_MODEL=Qwen/Qwen3.5-4B-Instruct

# ── RunPod ────────────────────────────────────────────────────────────────────
RUNPOD_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
RUNPOD_REASONER_ENDPOINT_ID=xxxxxxxxxx   # Your RunPod serverless endpoint ID for Gemma4
RUNPOD_CODER_ENDPOINT_ID=xxxxxxxxxx      # Your RunPod serverless endpoint ID for Qwen3.5

# ── Server ────────────────────────────────────────────────────────────────────
PORT=8000
LOG_LEVEL=info

# ── Thresholds ────────────────────────────────────────────────────────────────
LOCAL_MAX_QUEUE=4
HF_MAX_QUEUE=8
REQUEST_TIMEOUT_SECS=120
