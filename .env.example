# ── Models ────────────────────────────────────────────────────────────────────
# [1] Primary instruct — Kimi-VL-A3B iMatrix (vision, agent, long-ctx, 3B)
REASONER_MODEL=hf.co/mradermacher/Kimi-VL-A3B-Instruct-i1-GGUF:Q4_K_M

# [2] Tandem instruct — Hermes3 8B (reasoning support paired with Kimi)
TANDEM_MODEL=hermes3:8b

# [3] Primary multimodal — Qwen3-48B A4B active MoE, Q8_0 (DavidAU, original publisher)
CODER_MODEL=hf.co/DavidAU/Qwen3-48B-A4B-Savant-Commander-Distill-12X-Closed-Open-Heretic-Uncensored-GGUF:Q8_0

# [4] Fallback multimodal
FALLBACK_MODEL=hf.co/Jackrong/Qwopus3.6-27B-v1-preview-GGUF:Q8_0

# [5] Dedicated coder — Qwen3-Coder-30B-A3B (3B active MoE, ~96%+ HumanEval)
CODER_DEDICATED_MODEL=hf.co/Qwen/Qwen3-Coder-30B-A3B-Instruct-GGUF:Q6_K

# ── Ollama Cloud — signed-in device gives access to *:cloud variants ─────────
# After `ollama signin` on the ollama container (or mounting your host ~/.ollama)
# these models become available via the normal Ollama API:
#   kimi-k2:1t-cloud         — Kimi K2 (used by monitor)
#   gpt-oss:120b-cloud       — frontier reasoner overflow
#   qwen3-coder:480b-cloud   — frontier coder overflow
#   deepseek-v3.1:671b-cloud — frontier deep-research
OLLAMA_CLOUD_ENABLED=true
OLLAMA_CLOUD_ACCOUNT=nicholasjmcleod@gmail.com
OLLAMA_CLOUD_DEVICE=LN-8RDGA90Ultra

# ── Kimi K2 monitor (always-on, outside local orchestration) ─────────────────
# Primary: ollama-cloud kimi-k2:1t-cloud
# Fallback: OpenRouter moonshotai/kimi-k2 (uses OPENROUTER_API_KEY above)
KIMI_K2_MODEL=kimi-k2:1t-cloud
KIMI_K2_POLL_INTERVAL_SECS=30

# ── Compute strategy ──────────────────────────────────────────────────────────
# Options: round_robin | load_based | local_first | hf_first | runpod_first | openrouter_first
COMPUTE_STRATEGY=round_robin
LOCAL_WEIGHT=60
HF_WEIGHT=25
RUNPOD_WEIGHT=15

# ── HuggingFace (3 tokens — auto-rotated on rate limit) ──────────────────────
HF_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
HF_TOKEN_2=hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
HF_TOKEN_3=hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
HF_REASONER_MODEL=google/gemma-4-e4b-it
HF_CODER_MODEL=Qwen/Qwen3.5-4B-Instruct

# ── RunPod Serverless ─────────────────────────────────────────────────────────
RUNPOD_API_KEY=rpa_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
RUNPOD_S3_KEY=rps_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
RUNPOD_REASONER_ENDPOINT_ID=kukl55t0053lob
RUNPOD_CODER_ENDPOINT_ID=kukl55t0053lob

# ── OpenRouter (frontier fallback) ───────────────────────────────────────────
OPENROUTER_API_KEY=Sk-or-v1-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
OPENROUTER_REASONER_MODEL=google/gemma-2-27b-it:free
OPENROUTER_CODER_MODEL=qwen/qwen-2.5-coder-7b-instruct:free

# ── Shared infrastructure ─────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:PASSWORD@postgres.internal:5432/railway
REDIS_URL=redis://default:PASSWORD@redis.internal:6379

# ── Open WebUI ────────────────────────────────────────────────────────────────
WEBUI_SECRET_KEY=your-secret-key-here

# ── Server ────────────────────────────────────────────────────────────────────
PORT=8000
LOG_LEVEL=info
REQUEST_TIMEOUT_SECS=180
