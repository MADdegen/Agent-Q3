# =============================================================================
# Agent-Q3 Environment Variables
# Copy to .env and fill in your values
# =============================================================================

# -- Models ------------------------------------------------------------------
REASONER_MODEL=hf.co/unsloth/Qwen2.5-VL-32B-Instruct-GGUF:Q4_K_M
SUPPORT_MODEL=hf.co/TeichAI/Qwen3-8B-Kimi-K2-Thinking-Distill-GGUF:Q4_K_M
CODER_MODEL=hf.co/unsloth/QwQ-32B-GGUF:Q4_K_M

# -- Compute strategy --------------------------------------------------------
# Options: round_robin | load_based | local_first | hf_first | runpod_first | openrouter_first
COMPUTE_STRATEGY=local_first
LOCAL_WEIGHT=60
HF_WEIGHT=25
RUNPOD_WEIGHT=15

# -- HuggingFace (3 tokens - auto-rotated on rate limit) --------------------
HF_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
HF_TOKEN_2=hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
HF_TOKEN_3=hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
HF_REASONER_MODEL=Qwen/Qwen2.5-VL-32B-Instruct
HF_SUPPORT_MODEL=Qwen/Qwen3-8B
HF_CODER_MODEL=Qwen/QwQ-32B

# -- RunPod Serverless -------------------------------------------------------
RUNPOD_API_KEY=
RUNPOD_ENDPOINT_ID=

# -- OpenRouter fallback -----------------------------------------------------
OPENROUTER_API_KEY=

# -- Perplexity deep research ------------------------------------------------
PERPLEXITY_API_KEY=

# -- Search APIs (optional - free_search.py works without these) -------------
EXA_API_KEY=
TAVILY_API_KEY=
BRAVE_API_KEY=
FIRECRAWL_API_KEY=

# -- GitHub PAT (for GitHub search tool in free_search.py) ------------------
GITHUB_PAT=

# -- Railway (set automatically by Railway) ----------------------------------
PORT=8000
