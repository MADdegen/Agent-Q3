# ═══════════════════════════════════════════════════════════════════
# Agent-Q3 — Environment Variables
# ALL inference via Ollama Cloud (no local GGUFs, no GPU required)
# Account: nicholasjmcleod@gmail.com / Device: LN-8RDGA90Ultra
# ═══════════════════════════════════════════════════════════════════

# ── Ollama Cloud — ALL models are cloud variants ──────────────────
# Mount your host ~/.ollama into the ollama container for auth:
#   volumes:
#     - ~/.ollama:/root/.ollama
# OR run: docker exec -it agent-q3-ollama ollama signin
OLLAMA_CLOUD_ENABLED=true
OLLAMA_CLOUD_ACCOUNT=nicholasjmcleod@gmail.com
OLLAMA_CLOUD_DEVICE=LN-8RDGA90Ultra

# ── Cloud model assignments ───────────────────────────────────────
# [1] Reasoner — Kimi K2 1T (instruct / vision / agent / long-ctx)
REASONER_MODEL=kimi-k2:1t-cloud

# [2] Tandem — GPT-OSS 120B (reasoning partner / tandem stage-2)
TANDEM_MODEL=gpt-oss:120b-cloud

# [3] Coder — Qwen3-Coder 480B (primary multimodal / tandem stage-3)
CODER_MODEL=qwen3-coder:480b-cloud

# [4] Fallback — DeepSeek V3.1 671B (fallback / research overflow)
FALLBACK_MODEL=deepseek-v3.1:671b-cloud

# [5] Dedicated coder (same model as coder — Qwen3-Coder 480B)
CODER_DEDICATED_MODEL=qwen3-coder:480b-cloud

# ── Kimi K2 always-on monitor ─────────────────────────────────────
# Primary: Ollama Cloud kimi-k2:1t-cloud (same Ollama API)
# Fallback: OpenRouter moonshotai/kimi-k2 (if cloud unavailable)
KIMI_K2_MODEL=kimi-k2:1t-cloud
KIMI_K2_POLL_INTERVAL_SECS=30

# ── Compute strategy ──────────────────────────────────────────────
# local_first = Ollama Cloud first (the Ollama daemon IS the cloud proxy)
COMPUTE_STRATEGY=local_first
REQUEST_TIMEOUT_SECS=300

# ── HuggingFace (secondary compute — frontier models) ────────────
HF_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
HF_TOKEN_2=hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
HF_TOKEN_3=hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── RunPod Serverless (tertiary — GPU burst if needed) ────────────
RUNPOD_API_KEY=rpa_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
RUNPOD_REASONER_ENDPOINT_ID=kukl55t0053lob
RUNPOD_CODER_ENDPOINT_ID=kukl55t0053lob

# ── OpenRouter (monitor fallback + frontier overflow) ────────────
OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Research / Search APIs ────────────────────────────────────────
PERPLEXITY_API_KEY=pplx-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
EXA_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TAVILY_API_KEY=tvly-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
SMITHERY_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Shared infrastructure ─────────────────────────────────────────
DATABASE_URL=postgresql://postgres:PASSWORD@postgres.internal:5432/railway
REDIS_URL=redis://default:PASSWORD@redis.internal:6379

# ── Open WebUI ────────────────────────────────────────────────────
WEBUI_SECRET_KEY=change-me-to-a-random-secret

# ── Server ────────────────────────────────────────────────────────
PORT=8000
LOG_LEVEL=info
