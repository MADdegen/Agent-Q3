# ── Models ────────────────────────────────────────────────────────────────────
REASONER_MODEL=gemma4:e4b-instruct-q4_K_M
CODER_MODEL=qwen3.5:4b-instruct-q4_K_M

# ── Compute strategy ──────────────────────────────────────────────────────────
# Options: round_robin | load_based | local_first | hf_first | runpod_first | openrouter_first
COMPUTE_STRATEGY=round_robin
LOCAL_WEIGHT=60
HF_WEIGHT=25
RUNPOD_WEIGHT=15

# ── HuggingFace (3 tokens — auto-rotated on rate limit) ──────────────────────
HF_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
HF_TOKEN_2=hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
HF_TOKEN_3=hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
HF_REASONER_MODEL=google/gemma-4-e4b-it
HF_CODER_MODEL=Qwen/Qwen3.5-4B-Instruct

# ── RunPod Serverless ─────────────────────────────────────────────────────────
RUNPOD_API_KEY=rpa_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
RUNPOD_S3_KEY=rps_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
RUNPOD_REASONER_ENDPOINT_ID=kukl55t0053lob
RUNPOD_CODER_ENDPOINT_ID=kukl55t0053lob

# ── OpenRouter (frontier fallback) ───────────────────────────────────────────
OPENROUTER_API_KEY=Sk-or-v1-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
OPENROUTER_REASONER_MODEL=google/gemma-2-27b-it:free
OPENROUTER_CODER_MODEL=qwen/qwen-2.5-coder-7b-instruct:free

# ── Shared infrastructure ─────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:PASSWORD@postgres.railway.internal:5432/railway
REDIS_URL=redis://default:PASSWORD@redis.railway.internal:6379

# ── OpenWebUI ─────────────────────────────────────────────────────────────────
WEBUI_SECRET_KEY=your-secret-key-here

# ── Server ────────────────────────────────────────────────────────────────────
PORT=8000
LOG_LEVEL=info
REQUEST_TIMEOUT_SECS=180
