# ─────────────────────────────────────────────────────────────────────────────
# Agent-Q3 Ollama Cloud Proxy
#
# No local GGUFs stored here. This container is a signed-in Ollama daemon
# that proxies *:cloud model calls to ollama.com on behalf of the account.
#
# Auth: mount host ~/.ollama (contains id_ed25519 device key) as a volume,
# OR run `docker exec -it agent-q3-ollama ollama signin` once after first boot.
#
# Account: nicholasjmcleod@gmail.com
# Device:  LN-8RDGA90Ultra
# ─────────────────────────────────────────────────────────────────────────────
FROM ollama/ollama:latest

RUN apt-get update && apt-get install -y curl ca-certificates \
    && rm -rf /var/lib/apt/lists/*

COPY scripts/pull-models.sh /pull-models.sh
RUN chmod +x /pull-models.sh

ENV OLLAMA_HOST=0.0.0.0 \
    OLLAMA_ORIGINS="*" \
    OLLAMA_KEEP_ALIVE=24h \
    OLLAMA_MAX_LOADED_MODELS=4

EXPOSE 11434

ENTRYPOINT ["/pull-models.sh"]
